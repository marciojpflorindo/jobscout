# ── JobScout runtime data — NEVER commit ────────────────────────────────
# Everything personal is generated locally at runtime and stays out of git.

# Python virtual environment + caches
.venv/
__pycache__/
*.py[cod]
.pytest_cache/

# User profile (generated by onboarding; hand-editable). profile.example.md IS committed.
profile.md

# CV / résumé supplied by the user for ATS scoring (stored at the repo root).
# Root-anchored so they never swallow source files like ats/cv.py.
/cv.*
/resume.*
*.pdf
*.docx

# Dashboard JSON store + any backups
dashboard/store.json
dashboard/*.json
*.store.json

# Brain local state: scored/seen ledgers, reject ledger
brain/state/
brain/*.state.json
*.scored.json
*.seen.json
reject_ledger.json

# Generated output: reports, packets, scraped data
reports/
packets/
scrapes/

# Config holding the user's model choice and search settings
config.json
*.config.json

# Secrets
.env
.env.*

# Logs
*.log
logs/

# macOS
.DS_Store
